# Copia a .env y rellena valores reales.

PORT=3001
NODE_ENV=development
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

FRONTEND_URL=http://localhost:3000

JWT_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=7d

BOOTSTRAP_ADMIN_SECRET=cambiar-en-produccion

# Opcional: login admin con Google
GOOGLE_CLIENT_ID=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend — envío del código de invitación (POST /auth/admin/invite)
# https://resend.com/api-keys
RESEND_API_KEY=
# Remitente verificado en Resend (dominio propio). Vacío → onboarding@resend.dev:
# en ese modo Resend solo deja enviar al correo de TU cuenta Resend; para otros destinatarios verifica un dominio.
RESEND_FROM_EMAIL=
APP_PUBLIC_NAME=Shamell Admin
