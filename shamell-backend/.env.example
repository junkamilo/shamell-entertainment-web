# Copia a .env y rellena valores reales.

PORT=3001
NODE_ENV=development
# Postgres alojado (Supabase, Neon, etc.):
# - SUPABASE — App (transacción): puerto 6543, host *.pooler.supabase.com, usuario prisma.PROJECT_REF.
#   Cadena debe incluir pgbouncer=true (el código la añade si falta en 6543).
#   Migraciones (prisma migrate): DIRECT_URL con modo sesión 5432 o conexión directa al disco del proyecto.
# - NEON — DATABASE_URL con endpoint *-pooler.* (pooled); DIRECT_URL = endpoint direct (sin -pooler).
#   Tras suspensión, el primer request puede tardar: sube DATABASE_CONNECTION_TIMEOUT_MS si hace falta.
# - sslmode=verify-full evita el warning de node-pg sobre require/prefer/verify-ca.
#
# DIRECT_URL se usa para migraciones (prisma.config.ts): copia DATABASE_URL si no usas pooler separado.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?sslmode=verify-full&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full"
# Cliente pg (Nest): empieza en 1 para no saturar el plan; sube con cuidado.
DATABASE_POOL_MAX=1
# Milisegundos que pg espera una conexión del pool (Neon cold start, colas del pooler).
DATABASE_CONNECTION_TIMEOUT_MS=60000
# Opcional: connect_timeout en la URL (segundos); por defecto 30 si no está en la URL.
# DATABASE_CONNECT_TIMEOUT_SEC=30

# Origen del SPA (CORS). En producción incluye el dominio real y, si aplica, Vercel:
# FRONTEND_URL=https://www.shamellentertainment.com,https://shamell-entertainment-web.vercel.app
FRONTEND_URL=http://localhost:3000

# Reservas / disponibilidad — zona horaria IANA para interpretar fechas y ventanas HH:mm
BOOKING_TZ=America/New_York

JWT_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=7d

BOOTSTRAP_ADMIN_SECRET=cambiar-en-produccion

# Opcional: login admin con Google
GOOGLE_CLIENT_ID=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Opcional: subidas de imágenes del catálogo de eventos (admin → Eventos). Por defecto se usa la categoría con slug "event-catalog" (creada por migración).
# EVENT_CATALOG_GALLERY_CATEGORY_ID=
# EVENT_CATALOG_GALLERY_SLUG=event-catalog

# Opcional: fotos del header principal del home (módulo Header Media).
# HEADER_MEDIA_GALLERY_SLUG=home-header
# HEADER_MEDIA_GALLERY_NAME=Header Principal

# MailerSend — transaccional (invitación admin, confirmación de reservas, agradecimiento contacto/concierge, etc.)
# https://app.mailersend.com/api-tokens
# Dominio de prueba (*.mlsender.net): máx. 2 destinatarios únicos (error MS42225). Tras aprobar la cuenta,
# añade y verifica tu dominio en MailerSend y usa MAILERSEND_FROM_EMAIL con ese dominio (plan Free: 500/mes).
MAILERSEND_API_KEY=
# Remitente de un dominio verificado en MailerSend (no uses @*.mlsender.net en producción).
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=Shamell Admin
APP_PUBLIC_NAME=Shamell Admin
