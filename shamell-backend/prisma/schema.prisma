// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============
enum UserRole {
  ADMIN
  CLIENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BookingQuotePaymentModel {
  FULL
  DEPOSIT
}

enum BookingQuoteStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum BookingPaymentStage {
  FULL
  DEPOSIT
  BALANCE
}

enum BookingPaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

enum GalleryMediaType {
  IMAGE
  VIDEO
}

enum EventTypeOccasionUsage {
  OCCASION_SINGLE
  BESPOKE_PROJECT
  BESPOKE_ROLE
}

enum EventPublicSection {
  GENERAL
  UPCOMING_EVENTS
}

enum UpcomingExperienceType {
  CLASSES
  VENUE_SEATING
}

enum UpcomingClassVariant {
  GROUP
  PERSONAL
}

enum UpcomingClassEnrollmentStatus {
  PENDING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
}

enum ReservationEventScheduleMode {
  FIXED_EVENT
  RECURRING_WEEKLY
}

enum BookingSource {
  CLIENT_REGISTERED
  ADMIN_PHONE
  ADMIN_FROM_CONTACT
}

enum AvailabilityClosureKind {
  SPECIFIC_DATE
  RECURRING_WEEKDAY
  DATE_RANGE
}

enum ContactRequestStatus {
  PENDING
  RESERVED
  CANCELLED
}

enum VenueTableSize {
  LARGE
  MEDIUM
  SMALL
}

// ============ MODELS ============
model User {
  id                     String        @id @default(uuid())
  email                  String        @unique
  password               String?
  googleSub              String?       @unique
  fullName               String
  phone                  String?
  role                   UserRole      @default(CLIENT)
  twoFactorEnabled       Boolean       @default(false)
  twoFactorSecret        String?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  bookings               Booking[]     @relation("ClientBookings")
  bookingsCreatedAsAdmin Booking[]     @relation("AdminCreatedBookings")
  adminInvitesCreated    AdminInvite[] @relation("AdminInviteInvitedBy")
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@map("users")
}

model AdminInvite {
  id          String    @id @default(uuid())
  email       String
  codeHash    String
  fullName    String
  invitedById String
  invitedBy   User      @relation("AdminInviteInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
  @@map("admin_invites")
}

model Service {
  id            String         @id @default(uuid())
  serviceType   ServiceType    @relation(fields: [serviceTypeId], references: [id])
  serviceTypeId String         @unique
  description   String         @db.Text
  items         String[]
  price         Decimal?       @db.Decimal(12, 2)
  imageUrl      String?
  isActive      Boolean        @default(true)
  bookings      Booking[]
  galleryPhotos GalleryPhoto[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("services")
}

model ServiceType {
  id                 String         @id @default(uuid())
  name               String         @unique
  contactInquiryCode String?
  isActive           Boolean        @default(true)
  services           Service[]
  galleryPhotos      GalleryPhoto[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("service_types")
}

model Event {
  id              String                  @id @default(uuid())
  eventType       EventType               @relation(fields: [eventTypeId], references: [id])
  eventTypeId     String                  @unique
  description     String                  @db.Text
  items           String[]
  price           Decimal?                @db.Decimal(12, 2)
  isActive        Boolean                 @default(true)
  showOnHome      Boolean                 @default(true)
  publicSection   EventPublicSection      @default(GENERAL)
  slug            String?                 @unique
  experienceType  UpcomingExperienceType?
  classVariant    UpcomingClassVariant?
  galleryPhotos   GalleryPhoto[]
  bookings        Booking[]
  venueConfig     UpcomingVenueConfig?
  classSessions            UpcomingClassSession[]
  classPackageEnrollments  UpcomingClassPackageEnrollment[]
  fixedEventEnrollments    UpcomingFixedEventEnrollment[]
  seatReservations VenueSeatReservation[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@map("events")
}

model OccasionType {
  id         String              @id @default(uuid())
  name       String              @unique
  isActive   Boolean             @default(true)
  eventLinks EventTypeOccasion[]
  bookings   Booking[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@map("occasion_types")
}

model EventTypeOccasion {
  id             String                 @id @default(uuid())
  eventTypeId    String
  occasionTypeId String
  usage          EventTypeOccasionUsage
  sortOrder      Int                    @default(0)
  eventType      EventType              @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  occasionType   OccasionType           @relation(fields: [occasionTypeId], references: [id], onDelete: Cascade)

  @@unique([eventTypeId, occasionTypeId])
  @@index([eventTypeId])
  @@map("event_type_occasions")
}

model EventType {
  id                 String              @id @default(uuid())
  name               String              @unique
  contactInquiryCode String?
  isActive           Boolean             @default(true)
  events             Event[]
  occasionLinks      EventTypeOccasion[]
  galleryPhotos      GalleryPhoto[]
  bookings           Booking[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("event_types")
}

model GalleryCategory {
  id        String         @id @default(uuid())
  name      String         @unique
  slug      String         @unique
  isActive  Boolean        @default(true)
  photos    GalleryPhoto[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("gallery_categories")
}

model GalleryPhoto {
  id            String           @id @default(uuid())
  category      GalleryCategory  @relation(fields: [categoryId], references: [id])
  categoryId    String
  imageUrl      String
  imagePublicId String
  focalX        Int              @default(50)
  focalY        Int              @default(35)
  focalMobileX  Int              @default(50)
  focalMobileY  Int              @default(35)
  mediaType     GalleryMediaType @default(IMAGE)
  isActive      Boolean          @default(true)
  serviceId     String?
  serviceTypeId String?
  eventId       String?
  eventTypeId   String?
  service       Service?         @relation(fields: [serviceId], references: [id])
  serviceType   ServiceType?     @relation(fields: [serviceTypeId], references: [id])
  event         Event?           @relation(fields: [eventId], references: [id])
  eventType     EventType?       @relation(fields: [eventTypeId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([categoryId, isActive])
  @@map("gallery_photos")
}

model WeeklyAvailabilitySlot {
  id        String   @id @default(uuid())
  weekday   Int      @unique // 0 = Sunday … 6 = Saturday
  isClosed  Boolean  @default(false)
  startTime String? // HH:mm in BOOKING_TZ
  endTime   String? // HH:mm in BOOKING_TZ
  updatedAt DateTime @updatedAt

  @@map("weekly_availability_slots")
}

model AvailabilityClosure {
  id        String                  @id @default(uuid())
  kind      AvailabilityClosureKind
  date      DateTime?               @db.Date // SPECIFIC_DATE (calendar day closed)
  weekday   Int? // RECURRING_WEEKDAY (0–6), closes every such weekday
  startDate DateTime?               @db.Date // DATE_RANGE start (inclusive)
  endDate   DateTime?               @db.Date // DATE_RANGE end (inclusive)
  note      String?
  createdAt DateTime                @default(now())

  @@index([kind])
  @@map("availability_closures")
}

model Booking {
  id            String  @id @default(uuid())
  user          User?   @relation("ClientBookings", fields: [userId], references: [id])
  userId        String?
  guestFullName String?
  guestEmail    String?
  guestPhone    String?

  createdByAdmin   User?           @relation("AdminCreatedBookings", fields: [createdByAdminId], references: [id])
  createdByAdminId String?
  contactRequest   ContactRequest? @relation(fields: [contactRequestId], references: [id])
  contactRequestId String?

  source BookingSource @default(CLIENT_REGISTERED)

  service   Service @relation(fields: [serviceId], references: [id])
  serviceId String

  eventType      EventType?    @relation(fields: [eventTypeId], references: [id])
  eventTypeId    String?
  occasionType   OccasionType? @relation(fields: [occasionTypeId], references: [id])
  occasionTypeId String?
  event          Event?        @relation(fields: [eventId], references: [id])
  eventId        String?

  bookingDetails Json?

  eventDate          DateTime
  location           String
  guestCount         Int?
  notes              String?                   @db.Text
  status             BookingStatus             @default(PENDING)
  totalAmount        Decimal?                  @db.Decimal(10, 2)
  quoteModel         BookingQuotePaymentModel?
  quoteTotalAmount   Decimal?                  @db.Decimal(12, 2)
  quoteDepositAmount Decimal?                  @db.Decimal(12, 2)
  quoteBalanceAmount Decimal?                  @db.Decimal(12, 2)
  quoteCurrency      String                    @default("usd")
  quoteSentAt        DateTime?
  quoteAcceptedAt    DateTime?
  quoteRejectedAt    DateTime?
  depositPaidAt      DateTime?
  balancePaidAt      DateTime?
  quotes             BookingQuote[]
  payments           BookingPayment[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([eventDate])
  @@index([status])
  @@index([createdByAdminId])
  @@index([contactRequestId])
  @@map("bookings")
}

model BookingQuote {
  id             String                   @id @default(uuid())
  bookingId      String
  status         BookingQuoteStatus       @default(SENT)
  paymentModel   BookingQuotePaymentModel
  totalAmount    Decimal                  @db.Decimal(12, 2)
  depositAmount  Decimal?                 @db.Decimal(12, 2)
  balanceAmount  Decimal?                 @db.Decimal(12, 2)
  currency       String                   @default("usd")
  tokenHash      String
  tokenExpiresAt DateTime
  respondedAt    DateTime?
  rejectReason   String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  booking  Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payments BookingPayment[]

  @@index([bookingId, status])
  @@index([tokenExpiresAt])
  @@map("booking_quotes")
}

model BookingPayment {
  id                      String               @id @default(uuid())
  bookingId               String
  quoteId                 String
  stage                   BookingPaymentStage
  expectedAmount          Decimal              @db.Decimal(12, 2)
  currency                String               @default("usd")
  status                  BookingPaymentStatus @default(PENDING)
  stripeCheckoutSessionId String               @unique
  stripePaymentIntentId   String?
  expiresAt               DateTime?
  paidAt                  DateTime?
  customerEmailSentAt     DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  booking Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  quote   BookingQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([bookingId, stage, status])
  @@index([quoteId, stage])
  @@map("booking_payments")
}

model ContactRequest {
  id                      String               @id @default(uuid())
  fullName                String
  email                   String
  phone                   String?
  eventDate               DateTime?
  location                String?
  serviceType             String?
  preferences             String?              @db.Text
  subject                 String
  message                 String               @db.Text
  inquiryDetails          Json?
  /**
   * Fixed-shape JSON for "Tell us your vision" (concierge_gate) submissions; null for other contact flows.
   */
  conciergeVisionSnapshot Json?                @map("concierge_vision_snapshot")
  bookings                Booking[]
  isRead                  Boolean              @default(false)
  status                  ContactRequestStatus @default(PENDING)
  createdAt               DateTime             @default(now())

  @@index([status])
  @@map("contact_requests")
}

model Performer {
  id          String   @id @default(uuid())
  stageName   String
  bio         String?  @db.Text
  imageUrl    String?
  specialties String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("performers")
}

model AboutContent {
  id            String   @id @default(uuid())
  title         String
  paragraph1    String   @db.Text
  coreValues    String[]
  imageUrl      String?
  imagePublicId String?
  /// Pre-generated Cloudinary MP4 stream URL (eager on upload). Falls back to on-the-fly transform if null.
  videoDeliveryUrl String?
  /// Pre-generated poster frame JPG (eager on upload).
  videoPosterUrl   String?
  /// IMAGE or VIDEO — Cloudinary resource type for `imagePublicId` deletion and public rendering.
  heroMediaType String   @default("IMAGE")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("about_content")
}

model HeroHeaderContent {
  id            String   @id @default(uuid())
  headline      String   @default("SHAMELL")
  headlineFont  String   @default("brand")
  headlineColor String   @default("#c5a55a")
  tagline       String   @default("Exclusive Belly Dance Performance Artistry") @db.Text
  taglineFont   String   @default("elegant")
  taglineColor  String   @default("#f5e6b8")
  quote         String   @default("Dance is the hidden language of the soul.") @db.Text
  quoteFont     String   @default("script")
  quoteColor    String   @default("#c5a55a")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("hero_header_content")
}

model VenueFloorLayout {
  id                String                @id @default(uuid())
  viewBoxWidth      Int                   @default(1024)
  viewBoxHeight     Int                   @default(944)
  backgroundVersion String                @default("v1")
  items             Json                  @default("[]")
  sceneZones        Json                  @default("{}")
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  upcomingVenueConfigs UpcomingVenueConfig[]

  @@map("venue_floor_layouts")
}

model ReservationEventTemplate {
  id           String                       @id @default(uuid())
  name         String                       @unique
  timezone     String                       @default("America/New_York")
  scheduleMode ReservationEventScheduleMode @default(FIXED_EVENT)
  salesStartDate         DateTime? @db.Date
  salesEndDate           DateTime? @db.Date
  eventDate              DateTime? @db.Date
  eventStartTime         String?
  eventEndTime           String?
  recurringEffectiveFrom DateTime? @db.Date
  recurringStartTime     String?
  recurringEndTime         String?
  startDate              DateTime? @db.Date
  endDate                DateTime? @db.Date
  startTime              String?
  endTime                String?
  weekdays               ReservationEventWeekday[]
  classSections          ReservationEventClassSection[]
  venueConfigs           UpcomingVenueConfig[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("reservation_event_templates")
}

/// Recurring class time slot per weekday (e.g. Wed 06:00–10:00).
model ReservationEventClassSection {
  id              String                   @id @default(uuid())
  templateId      String
  template        ReservationEventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  weekday         Int
  label           String?
  startTime       String
  endTime         String
  sortOrder       Int                      @default(0)
  defaultCapacity Int                      @default(20)
  defaultPrice    Decimal?                 @db.Decimal(12, 2)
  isActive        Boolean                  @default(true)
  sessions        UpcomingClassSession[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([templateId, weekday, sortOrder])
  @@index([templateId, weekday])
  @@map("reservation_event_class_sections")
}

model ReservationEventWeekday {
  id         String                   @id @default(uuid())
  templateId String
  template   ReservationEventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  weekday    Int
  isActive   Boolean                  @default(true)

  @@unique([templateId, weekday])
  @@map("reservation_event_weekdays")
}

model UpcomingVenueConfig {
  id                         String    @id @default(uuid())
  eventId                    String    @unique
  event                      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  clientEnabled                Boolean   @default(false)
  promoTitle                   String?
  promoDescription             String?   @db.Text
  promoImageUrl                String?
  promoImagePublicId           String?
  reservationEventDate         DateTime?
  reservationOpensAt           DateTime?
  reservationClosesAt          DateTime?
  reservationEventLabel        String?
  reservationTimezone          String    @default("America/New_York")
  reservationEventTemplateId   String?
  reservationEventTemplate     ReservationEventTemplate? @relation(fields: [reservationEventTemplateId], references: [id], onDelete: SetNull)
  floorLayoutId                String?
  floorLayout                  VenueFloorLayout? @relation(fields: [floorLayoutId], references: [id], onDelete: SetNull)
  fixedTicketCapacity          Int?
  classPackageEnabled          Boolean   @default(false)
  classPackagePrice            Decimal?  @db.Decimal(12, 2)
  classPackageLabel            String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@index([reservationEventTemplateId])
  @@map("upcoming_venue_configs")
}

model UpcomingClassSession {
  id          String                        @id @default(uuid())
  eventId     String
  event       Event                         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sectionId   String?
  section     ReservationEventClassSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  weekday     Int?
  startsAt    DateTime
  endsAt      DateTime
  timezone    String                        @default("America/New_York")
  capacity    Int
  price       Decimal                       @db.Decimal(12, 2)
  currency    String                        @default("usd")
  isActive    Boolean                       @default(true)
  sortOrder   Int                           @default(0)
  enrollments UpcomingClassEnrollment[]
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  @@unique([eventId, sectionId, startsAt])
  @@index([eventId, startsAt])
  @@index([eventId, weekday, startsAt])
  @@map("upcoming_class_sessions")
}

model UpcomingClassEnrollment {
  id                      String                        @id @default(uuid())
  sessionId               String
  session                 UpcomingClassSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status                  UpcomingClassEnrollmentStatus @default(PENDING_PAYMENT)
  amount                  Decimal                       @db.Decimal(12, 2)
  currency                String                        @default("usd")
  /// Null when enrollment is part of a class package (checkout id lives on package row).
  stripeCheckoutSessionId String?                       @unique
  stripePaymentIntentId   String?
  paymentMethodType       String?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  customerName            String
  customerEmail           String
  customerPhone           String?
  paidAt                  DateTime?
  expiresAt               DateTime?
  customerEmailSentAt     DateTime?
  packageItem             UpcomingClassPackageEnrollmentItem?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt

  @@index([sessionId, status])
  @@map("upcoming_class_enrollments")
}

model UpcomingClassPackageEnrollment {
  id                      String                        @id @default(uuid())
  eventId                 String
  event                   Event                         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status                  UpcomingClassEnrollmentStatus @default(PENDING_PAYMENT)
  amount                  Decimal                       @db.Decimal(12, 2)
  currency                String                        @default("usd")
  stripeCheckoutSessionId String                        @unique
  stripePaymentIntentId   String?
  paymentMethodType       String?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  customerName            String
  customerEmail           String
  customerPhone           String?
  /// Snapshot of purchased sessions (bundle same-day or multi-day package).
  selections              Json
  paidAt                  DateTime?
  expiresAt               DateTime?
  customerEmailSentAt     DateTime?
  items                   UpcomingClassPackageEnrollmentItem[]
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt

  @@index([eventId, status])
  @@map("upcoming_class_package_enrollments")
}

model UpcomingClassPackageEnrollmentItem {
  id                  String                         @id @default(uuid())
  packageEnrollmentId String
  packageEnrollment   UpcomingClassPackageEnrollment @relation(fields: [packageEnrollmentId], references: [id], onDelete: Cascade)
  enrollmentId        String                         @unique
  enrollment          UpcomingClassEnrollment        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  weekday             Int

  @@index([packageEnrollmentId])
  @@map("upcoming_class_package_enrollment_items")
}

model UpcomingFixedEventEnrollment {
  id                      String                        @id @default(uuid())
  eventId                 String
  event                   Event                         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status                  UpcomingClassEnrollmentStatus @default(PENDING_PAYMENT)
  amount                  Decimal                       @db.Decimal(12, 2)
  currency                String                        @default("usd")
  stripeCheckoutSessionId String                        @unique
  stripePaymentIntentId   String?
  paymentMethodType       String?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  customerName            String
  customerEmail           String
  customerPhone           String?
  paidAt                  DateTime?
  expiresAt               DateTime?
  ticketNumber            Int?
  customerEmailSentAt     DateTime?
  adminNotifySentAt       DateTime?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt

  @@unique([eventId, ticketNumber])
  @@index([eventId, status])
  @@map("upcoming_fixed_event_enrollments")
}

enum VenueSeatReservationStatus {
  PENDING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
}

enum VenueSeatKind {
  CATALOG_TABLE
  STANDALONE_CHAIR
}

enum VenueReservationPaymentChannel {
  STRIPE
  CASH
}

model VenueTableConfig {
  id             String         @id @default(uuid())
  tableName      String
  size           VenueTableSize
  includedChairs Int
  bundlePrice    Decimal        @db.Decimal(12, 2)
  visualX        Float?
  visualY        Float?
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  seatReservations VenueSeatReservation[]

  @@map("venue_table_configs")
}

model VenueStandaloneChairConfig {
  id                String   @id @default(uuid())
  availableQuantity Int
  unitPrice         Decimal  @db.Decimal(12, 2)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("venue_standalone_chair_configs")
}

model VenueStandaloneChair {
  id        String   @id @default(uuid())
  chairName String
  unitPrice Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("venue_standalone_chairs")
}

/// Client-facing On Coming Events publish toggle and home promo (singleton row).
model VenueLayoutClientSettings {
  id                    String    @id @default(uuid())
  clientEnabled         Boolean   @default(false)
  promoTitle            String?
  promoDescription      String?   @db.Text
  promoImageUrl         String?
  promoImagePublicId    String?
  reservationEventDate  DateTime?
  /// When public seat sales open (On Coming Events reservations).
  reservationOpensAt    DateTime?
  /// When public seat sales close (unless sold out earlier).
  reservationClosesAt   DateTime?
  reservationEventLabel String?
  reservationTimezone   String    @default("America/New_York")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("venue_layout_client_settings")
}

model VenueSeatReservation {
  id                      String                     @id @default(uuid())
  upcomingEventId         String?
  upcomingEvent           Event?                     @relation(fields: [upcomingEventId], references: [id], onDelete: SetNull)
  kind                    VenueSeatKind
  venueTableConfigId      String?
  layoutItemId            String
  eventDate               DateTime
  amount                  Decimal                    @db.Decimal(12, 2)
  currency                String                     @default("usd")
  status                  VenueSeatReservationStatus       @default(PENDING_PAYMENT)
  paymentChannel          VenueReservationPaymentChannel     @default(STRIPE)
  stripeCheckoutSessionId String?                            @unique
  stripePaymentIntentId   String?
  payTokenHash            String?
  createdByAdminId        String?
  paymentMethodType       String?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  customerName            String
  customerEmail           String
  customerPhone           String?
  paidAt                  DateTime?
  expiresAt               DateTime?
  customerEmailSentAt     DateTime?
  createdAt               DateTime                           @default(now())
  updatedAt               DateTime                           @updatedAt

  venueTableConfig VenueTableConfig? @relation(fields: [venueTableConfigId], references: [id], onDelete: SetNull)

  // Partial unique index (PAID/PENDING only): see migration 20260610120000_venue_seat_partial_unique
  @@index([layoutItemId, upcomingEventId, status])
  @@index([upcomingEventId, status])
  @@index([status])
  @@map("venue_seat_reservations")
}

enum StripeWebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

model StripeWebhookEvent {
  id                String                         @id @default(uuid())
  eventId           String                         @unique
  eventType         String
  livemode          Boolean
  status            StripeWebhookProcessingStatus  @default(RECEIVED)
  metadataFlow      String?
  checkoutSessionId String?
  handler           String?
  payloadSummary    Json?
  processedAt       DateTime?
  attempts          Int                            @default(0)
  lastError         String?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  @@index([eventType, processedAt])
  @@index([checkoutSessionId])
  @@index([status, createdAt])
  @@map("stripe_webhook_events")
}
