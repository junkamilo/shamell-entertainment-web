// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============
enum UserRole {
  ADMIN
  CLIENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum GalleryMediaType {
  IMAGE
  VIDEO
}

enum EventTypeOccasionUsage {
  OCCASION_SINGLE
  BESPOKE_PROJECT
  BESPOKE_ROLE
}

// ============ MODELS ============
model User {
  id                     String        @id @default(uuid())
  email                  String        @unique
  password               String?
  googleSub              String?       @unique
  fullName               String
  phone                  String?
  role                   UserRole      @default(CLIENT)
  twoFactorEnabled       Boolean       @default(false)
  twoFactorSecret        String?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  bookings               Booking[]
  adminInvitesCreated    AdminInvite[] @relation("AdminInviteInvitedBy")
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@map("users")
}

model AdminInvite {
  id          String    @id @default(uuid())
  email       String
  codeHash    String
  fullName    String
  invitedById String
  invitedBy   User      @relation("AdminInviteInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
  @@map("admin_invites")
}

model Service {
  id            String      @id @default(uuid())
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])
  serviceTypeId String      @unique
  description   String      @db.Text
  items         String[]
  imageUrl      String?
  isActive      Boolean     @default(true)
  bookings      Booking[]
  galleryPhotos GalleryPhoto[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("services")
}

model ServiceType {
  id                  String    @id @default(uuid())
  name                String    @unique
  contactInquiryCode  String?
  isActive            Boolean   @default(true)
  services            Service[]
  galleryPhotos       GalleryPhoto[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("service_types")
}

model Event {
  id          String    @id @default(uuid())
  eventType   EventType @relation(fields: [eventTypeId], references: [id])
  eventTypeId String    @unique
  description String    @db.Text
  items       String[]
  isActive    Boolean   @default(true)
  showOnHome  Boolean   @default(true)
  galleryPhotos GalleryPhoto[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("events")
}

model OccasionType {
  id          String              @id @default(uuid())
  name        String              @unique
  isActive    Boolean             @default(true)
  eventLinks  EventTypeOccasion[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("occasion_types")
}

model EventTypeOccasion {
  id             String                @id @default(uuid())
  eventTypeId    String
  occasionTypeId String
  usage          EventTypeOccasionUsage
  sortOrder      Int                   @default(0)
  eventType      EventType             @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  occasionType   OccasionType          @relation(fields: [occasionTypeId], references: [id], onDelete: Cascade)

  @@unique([eventTypeId, occasionTypeId])
  @@index([eventTypeId])
  @@map("event_type_occasions")
}

model EventType {
  id                  String              @id @default(uuid())
  name                String              @unique
  contactInquiryCode  String?
  isActive            Boolean             @default(true)
  events              Event[]
  occasionLinks       EventTypeOccasion[]
  galleryPhotos       GalleryPhoto[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@map("event_types")
}

model GalleryCategory {
  id        String         @id @default(uuid())
  name      String         @unique
  slug      String         @unique
  isActive  Boolean        @default(true)
  photos    GalleryPhoto[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("gallery_categories")
}

model GalleryPhoto {
  id            String            @id @default(uuid())
  category      GalleryCategory   @relation(fields: [categoryId], references: [id])
  categoryId    String
  imageUrl      String
  imagePublicId String
  mediaType     GalleryMediaType  @default(IMAGE)
  isActive      Boolean           @default(true)
  serviceId     String?
  serviceTypeId String?
  eventId       String?
  eventTypeId   String?
  service       Service?          @relation(fields: [serviceId], references: [id])
  serviceType   ServiceType?      @relation(fields: [serviceTypeId], references: [id])
  event         Event?            @relation(fields: [eventId], references: [id])
  eventType     EventType?        @relation(fields: [eventTypeId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([categoryId, isActive])
  @@map("gallery_photos")
}

model Booking {
  id          String        @id @default(uuid())
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  service     Service       @relation(fields: [serviceId], references: [id])
  serviceId   String
  eventDate   DateTime
  location    String
  guestCount  Int?
  notes       String?       @db.Text
  status      BookingStatus @default(PENDING)
  totalAmount Decimal?      @db.Decimal(10, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("bookings")
}

model ContactRequest {
  id              String    @id @default(uuid())
  fullName        String
  email           String
  phone           String?
  eventDate       DateTime?
  location        String?
  serviceType     String?
  preferences     String?   @db.Text
  subject         String
  message         String    @db.Text
  inquiryDetails  Json?
  isRead          Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@map("contact_requests")
}

model Performer {
  id          String   @id @default(uuid())
  stageName   String
  bio         String?  @db.Text
  imageUrl    String?
  specialties String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("performers")
}

model AboutContent {
  id          String   @id @default(uuid())
  title       String
  paragraph1  String   @db.Text
  coreValues  String[]
  imageUrl    String?
  imagePublicId String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("about_content")
}


