{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "vitest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/test/**/*.ts",
    "src/test/**/*.tsx",
    "src/features/**/test/**/*.ts",
    "src/features/**/test/**/*.tsx"
  ],
  "exclude": ["node_modules", "**/tests/e2e/**"]
}
